# ============================================
# IHS AUDIT API — Configuration
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer le fichier .env
# ============================================

# ── APPLICATION ─────────────────────────────
PORT=3000
NODE_ENV=development
APP_NAME="IHS Audit API"

# ── MONGODB ATLAS ────────────────────────────
# Format : mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DB_NAME
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ihs_audit
MONGODB_DB_NAME=ihs_audit

# ── JWT ACCESS TOKEN ─────────────────────────
# Duree courte : 15m recommande en production
# Generer avec : node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=GENERER_UNE_CLE_ALEATOIRE_LONGUE_ICI
JWT_EXPIRES_IN=15m

# ── JWT REFRESH TOKEN ────────────────────────
# Doit etre DIFFERENT du JWT_SECRET
JWT_REFRESH_SECRET=GENERER_UNE_AUTRE_CLE_ALEATOIRE_LONGUE_ICI
JWT_REFRESH_EXPIRES_IN=30d

# ── CHIFFREMENT AES-256 ──────────────────────
# Generer avec : node -e "require('crypto').randomBytes(32).toString('hex')"
# Doit faire exactement 64 caracteres hexadecimaux
ENCRYPTION_KEY=GENERER_64_CARACTERES_HEX_ICI

# ── GEMINI AI ────────────────────────────────
# Obtenir sur : https://aistudio.google.com
GEMINI_API_KEY=AIzaSy_VOTRE_CLE_ICI
GEMINI_MODEL=gemini-1.5-flash

# ── STOCKAGE FICHIERS ────────────────────────
# 'local' = sauvegarde sur disque dans /uploads
# 's3'    = Cloudflare R2 ou MinIO
STORAGE=local

# ── CLOUDFLARE R2 (si STORAGE=s3) ───────────
# Obtenir sur : https://cloudflare.com → R2
MINIO_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=VOTRE_R2_ACCESS_KEY
MINIO_SECRET_KEY=VOTRE_R2_SECRET_KEY
MINIO_BUCKET=ihs-audit-photos
MINIO_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXX.r2.dev

# ── CORS ─────────────────────────────────────
# URLs autorisees a appeler l'API (separees par virgule)
# Dashboard web + App mobile
CORS_ORIGIN=http://localhost:3001,http://localhost:8081

# ── SECURITE ─────────────────────────────────
# Nombre de rounds bcrypt (12 mini, 14 recommande)
BCRYPT_ROUNDS=14
# Nombre de tentatives avant blocage IP
MAX_LOGIN_ATTEMPTS=5
# Duree du blocage en minutes
LOCK_TIME_MINUTES=30